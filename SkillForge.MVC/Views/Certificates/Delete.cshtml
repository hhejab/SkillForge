@model SkillForge.API.Models.Certificate

@{
    ViewData["Title"] = "Delete Certificate";
}

<div class="page-card">
    <h2 class="page-title">Delete Certificate</h2>
    <p class="page-subtitle">Confirm that you want to remove this certificate record.</p>

    <div class="alert alert-danger">
        Are you sure you want to delete this certificate?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Enrollment ID</dt>
        <dd class="col-sm-9">@(Model.Enrollment?.EnrollmentId)</dd>

        <dt class="col-sm-3">Certificate Code</dt>
        <dd class="col-sm-9">@Model.CertificateCode</dd>

        <dt class="col-sm-3">Issue Date</dt>
        <dd class="col-sm-9">@Model.IssueDate.ToString("dd MMM yyyy")</dd>

        <dt class="col-sm-3">Verification Status</dt>
        <dd class="col-sm-9">@(Model.VerificationStatus?.StatusName)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="CertificateId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>