@model IEnumerable<SkillForge.API.Models.Certificate>

@{
    ViewData["Title"] = "Certificate Management";
}

<div class="page-card">
    <h2 class="page-title">Certificate Management</h2>
    <p class="page-subtitle">Manage generated certificates, reference numbers, issue dates, and verification status.</p>

    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Certificate</a>
    </p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Enrollment ID</th>
                    <th>Certificate Reference</th>
                    <th>Issue Date</th>
                    <th>Verification Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Enrollment?.EnrollmentId</td>
                        <td><strong>@item.CertificateCode</strong></td>
                        <td>@item.IssueDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge bg-success">
                                @item.VerificationStatus?.StatusName
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.CertificateId" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.CertificateId" class="btn btn-sm btn-secondary">View</a>
                            <a asp-action="Delete" asp-route-id="@item.CertificateId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>