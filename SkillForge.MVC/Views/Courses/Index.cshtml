@model IEnumerable<SkillForge.API.Models.Course>

@{
    ViewData["Title"] = "Course Management";
}

<div class="page-card">
    <h2 class="page-title">Course Management</h2>
    <p class="page-subtitle">Manage training courses, categories, tracks, and course durations.</p>

    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Course</a>
    </p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Course Title</th>
                    <th>Description</th>
                    <th>Category</th>
                    <th>Track</th>
                    <th>Duration</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Title</strong></td>
                        <td>@item.Description</td>
                        <td>@item.Category?.CategoryName</td>
                        <td>@item.Track?.TrackName</td>
                        <td>@item.Duration hours</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.CourseId" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.CourseId" class="btn btn-sm btn-secondary">View</a>
                            <a asp-action="Delete" asp-route-id="@item.CourseId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>