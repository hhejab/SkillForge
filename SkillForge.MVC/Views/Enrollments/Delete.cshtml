@model SkillForge.API.Models.Enrollment

@{
    ViewData["Title"] = "Delete Enrollment";
}

<div class="page-card">
    <h2 class="page-title">Delete Enrollment</h2>
    <p class="page-subtitle">Confirm that you want to remove this enrollment record.</p>

    <div class="alert alert-danger">
        Are you sure you want to delete this enrollment?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Trainee</dt>
        <dd class="col-sm-9">@(Model.Trainee?.Email)</dd>

        <dt class="col-sm-3">Session ID</dt>
        <dd class="col-sm-9">@(Model.Session?.SessionId)</dd>

        <dt class="col-sm-3">Enrollment Date</dt>
        <dd class="col-sm-9">@Model.EnrollmentDate.ToString("dd MMM yyyy hh:mm tt")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@(Model.EnrollmentStatus?.StatusName)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="EnrollmentId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>