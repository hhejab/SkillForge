@model SkillForge.API.Models.Enrollment

@{
    ViewData["Title"] = "Enrollment Details";
}

<div class="page-card">
    <h2 class="page-title">Enrollment Details</h2>
    <p class="page-subtitle">View trainee enrollment details and current enrollment status.</p>

    <dl class="row">
        <dt class="col-sm-3">Trainee</dt>
        <dd class="col-sm-9">@(Model.Trainee?.Email)</dd>

        <dt class="col-sm-3">Trainee ID</dt>
        <dd class="col-sm-9">@Model.TraineeId</dd>

        <dt class="col-sm-3">Session ID</dt>
        <dd class="col-sm-9">@(Model.Session?.SessionId)</dd>

        <dt class="col-sm-3">Enrollment Date</dt>
        <dd class="col-sm-9">@Model.EnrollmentDate.ToString("dd MMM yyyy hh:mm tt")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@(Model.EnrollmentStatus?.StatusName)</dd>
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.EnrollmentId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>