@model IEnumerable<SkillForge.API.Models.Enrollment>

@{
    ViewData["Title"] = "Enrollment Management";
}

<div class="page-card">
    <h2 class="page-title">Enrollment Management</h2>
    <p class="page-subtitle">Manage trainee enrollments, sessions, and enrollment statuses.</p>

    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Enrollment</a>
    </p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Trainee ID</th>
                    <th>Trainee</th>
                    <th>Session ID</th>
                    <th>Enrollment Date</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TraineeId</td>
                        <td>@(item.Trainee?.Email)</td>
                        <td>@(item.Session?.SessionId)</td>
                        <td>@item.EnrollmentDate.ToString("dd MMM yyyy hh:mm tt")</td>
                        <td>
                            <span class="badge bg-primary">
                                @(item.EnrollmentStatus?.StatusName)
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.EnrollmentId" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.EnrollmentId" class="btn btn-sm btn-secondary">View</a>
                            <a asp-action="Delete" asp-route-id="@item.EnrollmentId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>