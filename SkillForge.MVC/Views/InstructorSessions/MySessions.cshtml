@model IEnumerable<SkillForge.API.Models.Session>

@{
    ViewData["Title"] = "My Sessions";
}

<div class="page-card">
    <h2 class="page-title">My Sessions</h2>
    <p class="page-subtitle">View your assigned sessions and record trainee results.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Room</th>
                    <th>Instructor</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Capacity</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in Model)
                {
                    <tr>
                        <td><strong>@session.Course?.Title</strong></td>
                        <td>@session.Room?.RoomName</td>
                        <td>@session.Instructor?.FullName</td>
                        <td>@session.StartDate.ToString("dd MMM yyyy hh:mm tt")</td>
                        <td>@session.EndDate.ToString("dd MMM yyyy hh:mm tt")</td>
                        <td>@session.Capacity</td>
                        <td>
                            <a asp-action="Trainees" asp-route-sessionId="@session.SessionId"
                               class="btn btn-primary btn-sm">
                                View Trainees
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
