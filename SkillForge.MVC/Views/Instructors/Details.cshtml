@model SkillForge.API.Models.Instructor

@{
    ViewData["Title"] = "Instructor Details";
}

<div class="page-card">
    <h2 class="page-title">Instructor Details</h2>
    <p class="page-subtitle">View instructor profile and contact information.</p>

    <dl class="row">
        <dt class="col-sm-3">User</dt>
        <dd class="col-sm-9">@(Model.User?.Email)</dd>

        <dt class="col-sm-3">Full Name</dt>
        <dd class="col-sm-9">@Model.FullName</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Phone</dt>
        <dd class="col-sm-9">@Model.Phone</dd>

        <dt class="col-sm-3">Specialization</dt>
        <dd class="col-sm-9">@Model.Specialization</dd>
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.InstructorId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>