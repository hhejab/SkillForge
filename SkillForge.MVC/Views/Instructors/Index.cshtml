@model IEnumerable<SkillForge.API.Models.Instructor>

@{
    ViewData["Title"] = "Instructor Management";
}

<div class="page-card">
    <h2 class="page-title">Instructor Management</h2>
    <p class="page-subtitle">Manage instructor profiles, contact details, and specialization areas.</p>

    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Instructor</a>
    </p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Instructor Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Specialization</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.FullName</strong></td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.Specialization</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.InstructorId" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.InstructorId" class="btn btn-sm btn-secondary">View</a>
                            <a asp-action="Delete" asp-route-id="@item.InstructorId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>