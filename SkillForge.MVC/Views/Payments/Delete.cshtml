@model SkillForge.API.Models.Payment

@{
    ViewData["Title"] = "Delete Payment";
}

<div class="page-card">
    <h2 class="page-title">Delete Payment</h2>
    <p class="page-subtitle">Confirm that you want to remove this payment record.</p>

    <div class="alert alert-danger">
        Are you sure you want to delete this payment?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Enrollment ID</dt>
        <dd class="col-sm-9">@(Model.Enrollment?.EnrollmentId)</dd>

        <dt class="col-sm-3">Amount</dt>
        <dd class="col-sm-9">@Model.Amount.ToString("0.000") BHD</dd>

        <dt class="col-sm-3">Payment Date</dt>
        <dd class="col-sm-9">@Model.PaymentDate.ToString("dd MMM yyyy")</dd>

        <dt class="col-sm-3">Payment Method</dt>
        <dd class="col-sm-9">@Model.PaymentMethod</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@(Model.PaymentStatus?.StatusName)</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="PaymentId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>