@model SkillForge.API.Models.Payment

@{
    ViewData["Title"] = "Payment Details";
}

<div class="page-card">
    <h2 class="page-title">Payment Details</h2>
    <p class="page-subtitle">View payment amount, method, date, and status.</p>

    <dl class="row">
        <dt class="col-sm-3">Enrollment ID</dt>
        <dd class="col-sm-9">@(Model.Enrollment?.EnrollmentId)</dd>

        <dt class="col-sm-3">Amount</dt>
        <dd class="col-sm-9">@Model.Amount.ToString("0.000") BHD</dd>

        <dt class="col-sm-3">Payment Date</dt>
        <dd class="col-sm-9">@Model.PaymentDate.ToString("dd MMM yyyy")</dd>

        <dt class="col-sm-3">Payment Method</dt>
        <dd class="col-sm-9">@Model.PaymentMethod</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@(Model.PaymentStatus?.StatusName)</dd>
    </dl>

    <a asp-action="Edit" asp-route-id="@Model.PaymentId" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>