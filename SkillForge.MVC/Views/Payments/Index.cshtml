@model IEnumerable<SkillForge.API.Models.Payment>

@{
    ViewData["Title"] = "Payment Management";
}

<div class="page-card">
    <h2 class="page-title">Payment Management</h2>
    <p class="page-subtitle">Track trainee payments, payment methods, and payment statuses.</p>

    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Payment</a>
    </p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Enrollment ID</th>
                    <th>Amount</th>
                    <th>Payment Date</th>
                    <th>Method</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Enrollment?.EnrollmentId</td>
                        <td>@item.Amount.ToString("0.000") BHD</td>
                        <td>@item.PaymentDate.ToString("dd MMM yyyy")</td>
                        <td>@item.PaymentMethod</td>
                        <td>
                            <span class="badge bg-primary">
                                @item.PaymentStatus?.StatusName
                            </span>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.PaymentId" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.PaymentId" class="btn btn-sm btn-secondary">View</a>
                            <a asp-action="Delete" asp-route-id="@item.PaymentId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>