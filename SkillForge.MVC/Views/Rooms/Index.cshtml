@model IEnumerable<SkillForge.API.Models.Room>

@{
    ViewData["Title"] = "Room Management";
}

<div class="page-card">
    <h2 class="page-title">Room Management</h2>
    <p class="page-subtitle">Manage classrooms, labs, room locations, and capacity limits.</p>

    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Room</a>
    </p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Room Name</th>
                    <th>Location</th>
                    <th>Capacity</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.RoomName</strong></td>
                        <td>@item.Location</td>
                        <td>@item.Capacity</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.RoomId" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.RoomId" class="btn btn-sm btn-secondary">View</a>
                            <a asp-action="Delete" asp-route-id="@item.RoomId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>