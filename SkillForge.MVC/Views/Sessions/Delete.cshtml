@model SkillForge.API.Models.Session

@{
    ViewData["Title"] = "Delete Session";
}

<div class="page-card">
    <h2 class="page-title">Delete Session</h2>
    <p class="page-subtitle">Confirm that you want to remove this scheduled session.</p>

    <div class="alert alert-danger">
        Are you sure you want to delete this session?
    </div>

    <dl class="row">
        <dt class="col-sm-3">Course</dt>
        <dd class="col-sm-9">@(Model.Course?.Title)</dd>

        <dt class="col-sm-3">Instructor</dt>
        <dd class="col-sm-9">@(Model.Instructor?.Email)</dd>

        <dt class="col-sm-3">Room</dt>
        <dd class="col-sm-9">@(Model.Room?.RoomName)</dd>

        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Model.StartDate.ToString("dd MMM yyyy hh:mm tt")</dd>

        <dt class="col-sm-3">End Date</dt>
        <dd class="col-sm-9">@Model.EndDate.ToString("dd MMM yyyy hh:mm tt")</dd>

        <dt class="col-sm-3">Capacity</dt>
        <dd class="col-sm-9">@Model.Capacity</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="SessionId" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>