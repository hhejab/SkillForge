@model IEnumerable<SkillForge.API.Models.Session>
@{
    ViewData["Title"] = "Scheduled Sessions";
    var enrollmentCounts = ViewBag.EnrollmentCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Scheduled Sessions</h2>
    <a asp-action="Create" class="btn btn-primary">
        <span>&#43;</span> Schedule New Session
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">
        No sessions have been scheduled yet. Click <strong>Schedule New Session</strong> to get started.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Course</th>
                    <th>Instructor</th>
                    <th>Room</th>
                    <th>Start</th>
                    <th>End</th>
                    <th class="text-center">Capacity</th>
                    <th class="text-center">Enrolled</th>
                    <th class="text-center">Available</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var session in Model)
                {
                    var enrolled = enrollmentCounts.GetValueOrDefault(session.SessionId, 0);
                    var available = session.Capacity - enrolled;
                    var availBadge = available > 0 ? "bg-success" : "bg-danger";

                    <tr>
                        <td>@(session.Course?.Title ?? $"Course #{session.CourseId}")</td>
                        <td>@(session.Instructor?.FullName ?? $"Instructor #{session.InstructorId}")</td>
                        <td>@session.Room</td>
                        <td>@session.StartDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>@session.EndDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td class="text-center">@session.Capacity</td>
                        <td class="text-center">@enrolled</td>
                        <td class="text-center">
                            <span class="badge @availBadge">@available</span>
                        </td>
                        <td class="text-end text-nowrap">
                            <a asp-action="Details" asp-route-id="@session.SessionId"
                               class="btn btn-sm btn-outline-secondary">Details</a>
                            <a asp-action="Edit" asp-route-id="@session.SessionId"
                               class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@session.SessionId"
                               class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
