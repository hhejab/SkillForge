@model IEnumerable<SkillForge.API.Models.Session>

@{
    ViewData["Title"] = "Session Scheduling";
}

<div class="page-card">
    <h2 class="page-title">Session Scheduling</h2>
    <p class="page-subtitle">Manage scheduled course sessions, assigned instructors, rooms, and capacity.</p>

    <p>
        <a asp-action="Create" class="btn btn-primary">Add New Session</a>
    </p>

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Instructor</th>
                    <th>Room</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Capacity</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Course?.Title</strong></td>
                        <td>@item.Instructor?.FullName</td>
                        <td>@item.Room?.RoomName</td>
                        <td>@item.StartDate.ToString("dd MMM yyyy hh:mm tt")</td>
                        <td>@item.EndDate.ToString("dd MMM yyyy hh:mm tt")</td>
                        <td>@item.Capacity</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.SessionId" class="btn btn-sm btn-primary">Edit</a>
                            <a asp-action="Details" asp-route-id="@item.SessionId" class="btn btn-sm btn-secondary">View</a>
                            <a asp-action="Delete" asp-route-id="@item.SessionId" class="btn btn-sm btn-danger">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>