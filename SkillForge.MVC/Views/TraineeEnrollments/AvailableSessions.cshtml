@model IEnumerable<SkillForge.API.Models.Session>

@{
    ViewData["Title"] = "Available Sessions";
}

<div class="page-card">
    <h2 class="page-title">Available Sessions</h2>
    <p class="page-subtitle">Browse sessions, check live availability, and enroll instantly.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Instructor</th>
                    <th>Room</th>
                    <th>Start</th>
                    <th>End</th>
                    <th>Capacity</th>
                    <th>Enrolled</th>
                    <th>Remaining</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var session in Model)
                {
                    var enrolledCount = session.Enrollments?.Count ?? 0;
                    var remaining = session.Capacity - enrolledCount;

                    <tr>
                        <td>
                            <strong>@session.Course?.Title</strong>
                        </td>
                        <td>@session.Instructor?.FullName</td>
                        <td>@session.Room?.RoomName</td>
                        <td>@session.StartDate.ToString("dd MMM yyyy hh:mm tt")</td>
                        <td>@session.EndDate.ToString("dd MMM yyyy hh:mm tt")</td>
                        <td>@session.Capacity</td>

                        <td>
                            <span id="enrolled-@session.SessionId" class="badge bg-primary">
                                @enrolledCount
                            </span>
                        </td>

                        <td>
                            <span id="remaining-@session.SessionId" class="badge bg-success">
                                @remaining
                            </span>
                        </td>

                        <td>
                            <form asp-action="Enroll" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="sessionId" value="@session.SessionId" />
                                <button type="submit" class="btn btn-primary btn-sm">
                                    Enroll
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script src="/lib/microsoft/signalr/dist/browser/signalr.js"></script>

<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/enrollmentHub")
        .withAutomaticReconnect()
        .build();

    connection.on("EnrollmentUpdated", function (sessionId, newCount) {
        console.log("SignalR update received:", sessionId, newCount);

        const enrolledCell = document.getElementById("enrolled-" + sessionId);
        const remainingCell = document.getElementById("remaining-" + sessionId);

        if (enrolledCell) {
            enrolledCell.innerText = newCount;
        }

        if (remainingCell) {
            const row = remainingCell.closest("tr");
            const capacity = parseInt(row.children[5].innerText);
            remainingCell.innerText = capacity - newCount;
        }
    });

    connection.start()
        .then(function () {
            console.log("SignalR connected.");
        })
        .catch(function (err) {
            console.error("SignalR connection error:", err.toString());
        });
</script>