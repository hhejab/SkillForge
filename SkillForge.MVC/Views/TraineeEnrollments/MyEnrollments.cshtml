@model IEnumerable<SkillForge.API.Models.Enrollment>

@{
    ViewData["Title"] = "My Enrollments";
    var trackProgress = ViewBag.TrackProgress as IEnumerable<dynamic>;
}

<div class="page-card">
    <h2 class="page-title">My Enrollments</h2>
    <p class="page-subtitle">View your enrolled sessions, results, and generated certificates.</p>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead>
                <tr>
                    <th>Course</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Enrolled On</th>
                    <th>Status</th>
                    <th>Result</th>
                    <th>Certificate</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var enrollment in Model)
                {
                    <tr>
                        <td><strong>@enrollment.Session?.Course?.Title</strong></td>
                        <td>@enrollment.Session?.StartDate.ToString("dd MMM yyyy")</td>
                        <td>@enrollment.Session?.EndDate.ToString("dd MMM yyyy")</td>
                        <td>@enrollment.EnrollmentDate.ToString("dd MMM yyyy")</td>
                        <td>
                            <span class="badge bg-primary">
                                @enrollment.EnrollmentStatus?.StatusName
                            </span>
                        </td>
                        <td>
                            @if (enrollment.Result != null)
                            {
                                var badgeColor = enrollment.Result.PassFail == "Pass" ? "bg-success" : "bg-danger";
                                <span class="badge @badgeColor">
                                    @enrollment.Result.PassFail
                                    @if (!string.IsNullOrEmpty(enrollment.Result.GradeOrScore))
                                    {
                                        <text> — @enrollment.Result.GradeOrScore</text>
                                    }
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">Pending</span>
                            }
                        </td>
                        <td>
                            @if (enrollment.Certificate != null)
                            {
                                <span class="badge bg-warning text-dark">
                                    🏆 @enrollment.Certificate.CertificateCode
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Certification Progress section — shows how far the trainee is in each track *@
    @if (trackProgress != null && trackProgress.Any())
    {
        <hr />
        <h4 class="mt-4">Certification Progress</h4>
        <p class="text-muted">Your progress toward completing each certification track.</p>

        <div class="row">
            @foreach (var track in trackProgress)
            {
                int passed = (int)track.Passed;
                int total = (int)track.Total;
                bool eligible = (bool)track.IsEligible;
                int pct = total > 0 ? (int)((passed / (double)total) * 100) : 0;

                <div class="col-md-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title">@track.TrackName</h6>
                            <p class="card-text text-muted mb-1">@passed / @total courses passed</p>
                            <div class="progress mb-2" style="height: 10px;">
                                <div class="progress-bar @(eligible ? "bg-success" : "bg-primary")"
                                     role="progressbar"
                                     style="width: @pct%"
                                     aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                            @if (eligible)
                            {
                                <span class="badge bg-success">Eligible for Certificate</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@pct% Complete</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
