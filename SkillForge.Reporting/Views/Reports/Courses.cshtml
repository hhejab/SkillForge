@model List<SkillForge.Reporting.Models.CourseReportDto>

@{
    ViewData["Title"] = "Courses Report";
}

<h1>Courses Report</h1>

<p class="text-muted">
    This report displays course records retrieved from the SkillForge API.
</p>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No course records found.
    </div>
}
else
{
    <div class="mb-3">
        <strong>Total Courses:</strong> @Model.Count
        <br />
        <strong>Total Duration:</strong> @Model.Sum(c => c.Duration) hours
    </div>

    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Course ID</th>
                <th>Title</th>
                <th>Description</th>
                <th>Category ID</th>
                <th>Track ID</th>
                <th>Duration</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var course in Model)
            {
                <tr>
                    <td>@course.CourseId</td>
                    <td>@course.Title</td>
                    <td>@course.Description</td>
                    <td>@course.CategoryId</td>
                    <td>@course.TrackId</td>
                    <td>@course.Duration hours</td>
                </tr>
            }
        </tbody>
    </table>
}