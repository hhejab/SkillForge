@model IEnumerable<SkillForge.Reporting.Models.EnrollmentReportDto>

@{
    ViewData["Title"] = "Enrollment Report";
}

<h2>Enrollment Report</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Course</th>
            <th>Category</th>
            <th>Total Enrollments</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseTitle</td>
                <td>@item.Category</td>
                <td>@item.TotalEnrollments</td>
            </tr>
        }
    </tbody>
</table>