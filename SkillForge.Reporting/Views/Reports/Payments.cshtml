@model IEnumerable<SkillForge.Reporting.Models.PaymentReportDto>

@{
    ViewData["Title"] = "Revenue Report";
}

<h2>Revenue Report</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Payment ID</th>
            <th>Enrollment ID</th>
            <th>Amount</th>
            <th>Date</th>
            <th>Method</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.PaymentId</td>
                <td>@item.EnrollmentId</td>
                <td>@item.Amount</td>
                <td>@item.PaymentDate.ToShortDateString()</td>
                <td>@item.PaymentMethod</td>
                <td>@item.Status</td>
            </tr>
        }
    </tbody>
</table>