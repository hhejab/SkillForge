@model IEnumerable<SkillForge.Reporting.Models.SessionReportDto>

@{
    ViewData["Title"] = "Sessions Report";
}

<h2>Sessions Report</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Course</th>
            <th>Instructor</th>
            <th>Room</th>
            <th>Start</th>
            <th>End</th>
            <th>Capacity</th>
            <th>Enrolled</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.CourseTitle</td>
                <td>@item.InstructorName</td>
                <td>@item.RoomName</td>
                <td>@item.StartDate</td>
                <td>@item.EndDate</td>
                <td>@item.Capacity</td>
                <td>@item.EnrolledCount</td>
            </tr>
        }
    </tbody>
</table>